{
  "experiment_id": "C4",
  "dataset": "Flowers102",
  "seed": 42,
  "model_type": "ResNet18",
  "pretrained": true,
  "num_classes": 102,
  "input_size": [
    3,
    224,
    224
  ],
  "train_mode": "layer4+fc",
  "transforms": {
    "train": "train_tf",
    "eval": "eval_tf"
  },
  "preprocess": {
    "resize": 256,
    "center_crop": 224,
    "to_tensor": true,
    "normalize_mean": [
      0.485,
      0.456,
      0.406
    ],
    "normalize_std": [
      0.229,
      0.224,
      0.225
    ]
  },
  "augmentation": {
    "resize": 256,
    "random_resized_crop": {
      "size": 224,
      "scale": [
        0.7,
        1.0
      ]
    },
    "random_horizontal_flip": {
      "p": 0.5
    }
  },
  "loss": "CrossEntropyLoss",
  "optimizer": "Adam",
  "lr": 0.001,
  "epochs_trained": 2
}